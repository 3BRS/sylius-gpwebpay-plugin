{
    "name": "3brs/sylius-gpwebpay-plugin",
    "replace": {
        "3brs/sylius-gpwebpay-payment-gateway-plugin": "self.version"
    },
    "type": "sylius-plugin",
    "description": "GPWebpay payment gateway plugin for Sylius",
    "keywords": [
        "sylius",
        "sylius-plugin",
        "plugin",
        "GPWebPay",
        "payment",
        "gateway"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-openssl": "*",
        "ext-simplexml": "*",
        "alcohol/iso4217": "^4.2",
        "sylius/sylius": "~2.0.6 || ~2.1.0 || ~2.2.0"
    },
    "require-dev": {
        "ext-intl": "*",
        "ext-pdo": "*",
        "ext-xml": "*",
        "behat/behat": "^3.17",
        "dmore/behat-chrome-extension": "^1.4",
        "dmore/chrome-mink-driver": "^2.9",
        "friends-of-behat/mink": "^1.11",
        "friends-of-behat/mink-browserkit-driver": "^1.6",
        "friends-of-behat/mink-debug-extension": "^2.1",
        "friends-of-behat/mink-extension": "^2.7",
        "friends-of-behat/page-object-extension": "^0.3",
        "friends-of-behat/suite-settings-extension": "^1.1",
        "friends-of-behat/symfony-extension": "^2.6",
        "friends-of-behat/variadic-extension": "^1.6",
        "nyholm/psr7": "^1.8",
        "phpspec/phpspec": "^7.5",
        "phpstan/phpstan": "^1.12",
        "phpstan/phpstan-doctrine": "^1.5.7",
        "phpstan/phpstan-webmozart-assert": "^1.2",
        "phpunit/phpunit": "^10.5",
        "robertfausk/behat-panther-extension": "^1.1",
        "sylius-labs/coding-standard": "^4.4",
        "sylius-labs/suite-tags-extension": "~0.2",
        "sylius/payum-bundle": "*",
        "sylius/sylius-rector": "^2.0",
        "symfony/asset": "^7.1",
        "symfony/browser-kit": "^7.1",
        "symfony/cache": "^7.1",
        "symfony/config": "^7.1",
        "symfony/console": "^7.1",
        "symfony/debug-bundle": "^7.1",
        "symfony/dependency-injection": "^7.1",
        "symfony/doctrine-bridge": "^7.1",
        "symfony/dotenv": "^7.1",
        "symfony/event-dispatcher": "^7.1",
        "symfony/expression-language": "^7.1",
        "symfony/finder": "^7.1",
        "symfony/flex": "^2.4",
        "symfony/form": "^7.1",
        "symfony/framework-bundle": "^7.1",
        "symfony/http-client": "^7.1",
        "symfony/http-foundation": "^7.1",
        "symfony/http-kernel": "^7.1",
        "symfony/intl": "^7.1",
        "symfony/mailer": "^7.1",
        "symfony/maker-bundle": "^1.0",
        "symfony/messenger": "^7.1",
        "symfony/property-access": "^7.1",
        "symfony/property-info": "^7.1",
        "symfony/routing": "^7.1",
        "symfony/security-bundle": "^7.1",
        "symfony/serializer": "^7.1",
        "symfony/translation": "^7.1",
        "symfony/twig-bridge": "^7.1",
        "symfony/twig-bundle": "^7.1",
        "symfony/validator": "^7.1",
        "symfony/web-profiler-bundle": "^7.1",
        "symfony/webpack-encore-bundle": "^2.2",
        "symfony/workflow": "^7.1",
        "symfony/yaml": "^7.1"
    },
    "conflict": {
        "api-platform/core": "<2.7.13",
        "api-platform/json-schema": "<4.2.0",
        "api-platform/symfony": "<v4.1.0",
        "babdev/pagerfanta-bundle": "<3.7.0",
        "doctrine/annotations": "<1.13.2",
        "doctrine/collections": "<1.7.0",
        "doctrine/data-fixtures": "<1.5.1",
        "doctrine/dbal": "<2.13.3",
        "doctrine/doctrine-bundle": "<2.8.0",
        "fakerphp/faker": "<1.21.0",
        "friendsofsymfony/rest-bundle": "<3.1.0",
        "jms/serializer-bundle": "<4.2.0",
        "masterminds/html5": "<2.7.5",
        "knplabs/knp-menu": "<3.3.0",
        "knplabs/knp-menu-bundle": "<3.5.0",
        "lexik/jwt-authentication-bundle": "<2.12",
        "payum/core": "<1.7.3",
        "polishsymfonycommunity/symfony-mocker-container": "<1.0.6",
        "sylius/grid-bundle": "<1.11.0",
        "sylius/sylius": "<2.0.6",
        "sylius/resource-bundle": "<1.10.0",
        "symfony/css-selector": "<4.4.24",
        "symfony/dom-crawler": "<5.4.0",
        "symfony/mime": "<5.4.0",
        "symfony/web-link": "<5.3.0",
        "symfony/var-dumper": "<5.4.0",
        "symplify/easy-coding-standard": "<10.3.0",
        "twig/twig": "<2.14.7",
        "webmozart/assert": "<1.11.0",
        "willdurand/negotiation": "<3.0"
    },
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "ThreeBRS\\SyliusGPWebpayPaymentGatewayPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\ThreeBRS\\SyliusGPWebpayPaymentGatewayPlugin\\": "tests/Application/src/",
            "Tests\\ThreeBRS\\SyliusGPWebpayPaymentGatewayPlugin\\Behat\\": "tests/Behat/"
        }
    },
    "config": {
        "sort-packages": true,
        "audit": {
            "abandoned": "ignore",
            "block-insecure": false
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": false,
            "phpstan/extension-installer": true,
            "symfony/flex": false,
            "php-http/discovery": false
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php bin/create_node_symlink.php"
        ],
        "post-update-cmd": [
            "php bin/create_node_symlink.php"
        ],
        "post-create-project-cmd": [
            "php bin/create_node_symlink.php"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "COMPOSER_AUDIT_ABANDONED=ignore composer audit": "script"
        }
    }
}
